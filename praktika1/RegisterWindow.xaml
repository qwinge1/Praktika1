<Window x:Class="praktika1.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="300" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Регистрация нового пользователя" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Email:"/>
            <TextBox x:Name="txtEmail" Margin="0,5,0,10"/>
            <TextBlock Text="Пароль (не менее 8 символов, A-Z, a-z, 0-9, спецсимвол):"/>
            <PasswordBox x:Name="txtPassword" Margin="0,5,0,10"/>
            <TextBlock Text="Подтверждение пароля:"/>
            <PasswordBox x:Name="txtConfirm" Margin="0,5,0,10"/>
            <TextBlock Text="Способ регистрации:"/>
            <ComboBox x:Name="cmbMethod" SelectedIndex="0" Margin="0,5,0,10">
                <ComboBoxItem Content="Прямой SQL"/>
                <ComboBoxItem Content="Хранимая процедура"/>
                <ComboBoxItem Content="Entity Framework"/>
            </ComboBox>
            <Button x:Name="btnRegister" Content="Зарегистрироваться" Height="30" Click="BtnRegister_Click"/>
        </StackPanel>
    </Grid>
</Window>