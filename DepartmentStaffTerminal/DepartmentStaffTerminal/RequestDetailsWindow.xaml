<Window x:Class="DepartmentStaffTerminal.Views.RequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление посещением" Height="600" Width="800"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Информация о заявке">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Тип:"/>
                        <TextBlock x:Name="txtType" Grid.Column="1"/>
                        <TextBlock Text="Подразделение:" Grid.Row="1"/>
                        <TextBlock x:Name="txtDepartment" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="Дата начала:" Grid.Row="2"/>
                        <TextBlock x:Name="txtStartDate" Grid.Row="2" Grid.Column="1"/>
                        <TextBlock Text="Дата окончания:" Grid.Row="3"/>
                        <TextBlock x:Name="txtEndDate" Grid.Row="3" Grid.Column="1"/>
                        <TextBlock Text="Цель:" Grid.Row="4"/>
                        <TextBlock x:Name="txtPurpose" Grid.Row="4" Grid.Column="1"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Посетители" Margin="0,10,0,0">
                    <DataGrid x:Name="dgVisitors" AutoGenerateColumns="False" IsReadOnly="True" Height="150"
                              MouseRightButtonUp="DgVisitors_MouseRightButtonUp">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Добавить в чёрный список" Click="AddToBlacklist_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}"/>
                            <DataGridTextColumn Header="Паспорт" Binding="{Binding Passport}"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}"/>
                            <DataGridTextColumn Header="Вход" Binding="{Binding EntryTime, StringFormat=HH:mm}"/>
                            <DataGridTextColumn Header="Выход" Binding="{Binding ExitTime, StringFormat=HH:mm}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GroupBox Header="Документы" Margin="0,10,0,0">
                    <ListBox x:Name="lbDocuments" Height="80"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnConfirmArrival" Content="Подтвердить прибытие" Width="160" Height="30"
                    Click="BtnConfirmArrival_Click" IsEnabled="False"/>
            <Button x:Name="btnConfirmDeparture" Content="Зафиксировать убытие" Width="160" Height="30" Margin="10,0,0,0"
                    Click="BtnConfirmDeparture_Click" IsEnabled="False"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="80" Height="30" Margin="10,0,0,0" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>