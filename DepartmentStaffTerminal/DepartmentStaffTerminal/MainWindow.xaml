<Window x:Class="DepartmentStaffTerminal.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал подразделения" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dtpFrom" Width="120" Margin="0,0,10,0" SelectedDateChanged="FilterChanged"/>
            <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dtpTo" Width="120" Margin="0,0,10,0" SelectedDateChanged="FilterChanged"/>
            <Button x:Name="btnRefresh" Content="Обновить" Width="80" Click="BtnRefresh_Click"/>
        </StackPanel>

        <DataGrid x:Name="dgRequests" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  MouseDoubleClick="DgRequests_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding DepartmentName}"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}"/>
                <DataGridTextColumn Header="Цель" Binding="{Binding Purpose}"/>
                <DataGridTextColumn Header="Заявитель" Binding="{Binding Applicant}"/>
                <DataGridTextColumn Header="Статус прохода" Binding="{Binding VisitStatus}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>