<Window x:Class="OfficeStaffTerminal.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Терминал общего отдела – Вход" Height="200" Width="350"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen" 
        >
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Введите код сотрудника" FontSize="16" Margin="0,0,0,20"/>
            <TextBox x:Name="txtCode" Margin="0,5,0,15"/>
            <Button x:Name="btnLogin" Content="Войти" Height="30" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>