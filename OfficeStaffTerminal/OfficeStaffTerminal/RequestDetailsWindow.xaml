<Window x:Class="OfficeStaffTerminal.RequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проверка заявки" Height="660" Width="923"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Информация о заявке">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Тип:"/>
                        <TextBlock x:Name="txtType" Grid.Column="1"/>
                        <TextBlock Text="Статус:" Grid.Row="1"/>
                        <TextBlock x:Name="txtStatus" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="Подразделение:" Grid.Row="2"/>
                        <TextBlock x:Name="txtDepartment" Grid.Row="2" Grid.Column="1"/>
                        <TextBlock Text="Дата начала:" Grid.Row="3"/>
                        <TextBlock x:Name="txtStartDate" Grid.Row="3" Grid.Column="1"/>
                        <TextBlock Text="Дата окончания:" Grid.Row="4"/>
                        <TextBlock x:Name="txtEndDate" Grid.Row="4" Grid.Column="1"/>
                        <TextBlock Text="Цель:" Grid.Row="5"/>
                        <TextBlock x:Name="txtPurpose" Grid.Row="5" Grid.Column="1"/>
                        <TextBlock Text="Время посещения:" Grid.Row="6"/>
                        <DatePicker x:Name="dtpVisitDate" Grid.Row="6" Grid.Column="1" Margin="0,2"/>
                        <TextBlock Text="Время:" Grid.Row="7"/>
                        <TextBox x:Name="txtVisitTime" Grid.Row="7" Grid.Column="1" Width="100" HorizontalAlignment="Left"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Посетители" Margin="0,10,0,0">
                    <DataGrid x:Name="dgVisitors" AutoGenerateColumns="False" IsReadOnly="True" Height="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}"/>
                            <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}"/>
                            <DataGridTextColumn Header="Паспорт" Binding="{Binding Passport}"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}"/>
                            <DataGridTextColumn Header="В чёрном списке" Binding="{Binding InBlacklistText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GroupBox Header="Документы" Margin="0,10,0,0">
                    <ListBox x:Name="lbDocuments" Height="80"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="cmbNewStatus" Width="150" Margin="0,0,10,0" DisplayMemberPath="Name" SelectedValuePath="Id"/>
            <Button x:Name="btnSave" Content="Сохранить" Width="80" Click="BtnSave_Click" IsEnabled="False"/>
            <Button x:Name="btnCancel" Content="Закрыть" Width="80" Margin="10,0,0,0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>