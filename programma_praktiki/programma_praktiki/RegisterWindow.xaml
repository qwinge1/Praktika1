<Window x:Class="programma_praktiki.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="421" Width="418" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Регистрация нового пользователя" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Email:"/>
            <TextBox x:Name="txtEmail" Margin="0,5,0,10"/>
            <TextBlock Text="Пароль (не менее 8 символов, A-Z, a-z, 0-9, спецсимвол):"/>
            <Grid>
                <PasswordBox x:Name="txtPassword" Margin="0,5,0,10" />
                <TextBox x:Name="txtPasswordVisible" Margin="0,5,0,10" Visibility="Collapsed" />
            </Grid>
            <CheckBox x:Name="chkShowPassword" Content="Показать пароль" Margin="0,0,0,10"
                      Checked="ChkShowPassword_Checked" Unchecked="ChkShowPassword_Unchecked"/>
            <TextBlock Text="Подтверждение пароля:"/>
            <Grid>
                <PasswordBox x:Name="txtConfirm" Margin="0,5,0,10" />
                <TextBox x:Name="txtConfirmVisible" Margin="0,5,0,10" Visibility="Collapsed" />
            </Grid>
            <CheckBox x:Name="chkShowConfirm" Content="Показать подтверждение" Margin="0,0,0,10"
                      Checked="ChkShowConfirm_Checked" Unchecked="ChkShowConfirm_Unchecked"/>
            <TextBlock Text="Способ регистрации:"/>
            <ComboBox x:Name="cmbMethod" SelectedIndex="0" Margin="0,5,0,10">
                <ComboBoxItem Content="Прямой SQL"/>
                <ComboBoxItem Content="Хранимая процедура"/>
                <ComboBoxItem Content="ORM-технология"/>
            </ComboBox>
            <Button x:Name="btnRegister" Content="Зарегистрироваться" Height="30" Click="BtnRegister_Click"/>
        </StackPanel>
    </Grid>
</Window>