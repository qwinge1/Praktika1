<Window x:Class="programma_praktiki.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ХранительПРО" Height="794" Width="927" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="Подача заявки">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Информация для пропуска" Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата начала:" VerticalAlignment="Center"/>
                                    <DatePicker x:Name="dtpStart" Grid.Column="1" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата окончания:" VerticalAlignment="Center"/>
                                    <DatePicker x:Name="dtpEnd" Grid.Column="1" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Цель посещения:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbPurpose" Grid.Column="1" Margin="5" IsEditable="True">
                                        <ComboBoxItem Content="Деловая встреча"/>
                                        <ComboBoxItem Content="Экскурсия"/>
                                        <ComboBoxItem Content="Техническое обслуживание"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Принимающая сторона" Grid.Row="1" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Подразделение:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbDepartment" Grid.Column="1" Margin="5" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CmbDepartment_SelectionChanged"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Сотрудник:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbEmployee" Grid.Column="1" Margin="5" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Информация о посетителе" Grid.Row="2" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Фамилия:"/>
                                    <TextBox x:Name="txtLastName" Grid.Column="1" Margin="5"/>
                                    <TextBlock Text="Имя:" Grid.Column="2"/>
                                    <TextBox x:Name="txtFirstName" Grid.Column="3" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Отчество:"/>
                                    <TextBox x:Name="txtMiddleName" Grid.Column="1" Margin="5"/>
                                    <TextBlock Text="Телефон:" Grid.Column="2"/>
                                    <TextBox x:Name="txtPhone" Grid.Column="3" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Email:"/>
                                    <TextBox x:Name="txtEmail" Grid.Column="1" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Организация:"/>
                                    <TextBox x:Name="txtOrg" Grid.Column="1" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Примечание:"/>
                                    <TextBox x:Name="txtNote" Grid.Column="1" Margin="5" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата рождения:"/>
                                    <DatePicker x:Name="dtpBirth" Grid.Column="1" Margin="5"/>
                                    <TextBlock Text="Серия паспорта:" Grid.Column="2"/>
                                    <TextBox x:Name="txtSeries" Grid.Column="3" Margin="5" MaxLength="4" PreviewTextInput="TextBoxOnlyDigits_PreviewTextInput"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Номер паспорта:"/>
                                    <TextBox x:Name="txtNumber" Grid.Column="1" Margin="5" MaxLength="6" PreviewTextInput="TextBoxOnlyDigits_PreviewTextInput"/>
                                    <TextBlock Text="Фото:" Grid.Column="2"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                                        <Button x:Name="btnLoadPhoto" Content="Загрузить JPG" Click="BtnLoadPhoto_Click"/>
                                        <Image x:Name="imgPhoto" Width="50" Height="60" Margin="5,0,0,0" Stretch="Uniform"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Документы" Grid.Row="3" Margin="0,0,0,10">
                            <StackPanel>
                                <Button x:Name="btnLoadScan" Content="Загрузить скан паспорта (PDF)" Click="BtnLoadScan_Click"/>
                                <TextBlock x:Name="txtScanPath" Margin="0,5,0,0" Foreground="Gray"/>
                            </StackPanel>
                        </GroupBox>

                        <Button x:Name="btnSubmit" Content="Отправить заявку" Grid.Row="4" Height="30" Click="BtnSubmit_Click"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Мои заявки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbFilterStatus" Width="150" Margin="5,0,0,0" SelectionChanged="CmbFilterStatus_SelectionChanged">
                            <ComboBoxItem Content="Все" IsSelected="True"/>
                            <ComboBoxItem Content="проверка"/>
                            <ComboBoxItem Content="одобрена"/>
                            <ComboBoxItem Content="не одобрена"/>
                        </ComboBox>
                        <Button x:Name="btnRefresh" Content="Обновить" Margin="10,0,0,0" Click="BtnRefresh_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgApplications" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,10,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="Подразделение" Binding="{Binding Department}"/>
                            <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}"/>
                            <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=dd.MM.yyyy}"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
                            <DataGridTextColumn Header="Причина отказа" Binding="{Binding RejectionReason}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Групповая заявка">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Информация для пропуска -->
                        <GroupBox Header="Информация для пропуска" Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата начала:" VerticalAlignment="Center"/>
                                    <DatePicker x:Name="dtpGroupStart" Grid.Column="1" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Дата окончания:" VerticalAlignment="Center"/>
                                    <DatePicker x:Name="dtpGroupEnd" Grid.Column="1" Margin="5"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Цель посещения:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbGroupPurpose" Grid.Column="1" Margin="5" IsEditable="True">
                                        <ComboBoxItem Content="Деловая встреча"/>
                                        <ComboBoxItem Content="Экскурсия"/>
                                        <ComboBoxItem Content="Техническое обслуживание"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Принимающая сторона -->
                        <GroupBox Header="Принимающая сторона" Grid.Row="1" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Подразделение:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbGroupDepartment" Grid.Column="1" Margin="5" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CmbGroupDepartment_SelectionChanged"/>
                                </Grid>
                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Сотрудник:" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="cmbGroupEmployee" Grid.Column="1" Margin="5" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Список участников -->
                        <GroupBox Header="Участники группы (минимум 5)" Grid.Row="2" Margin="0,0,0,10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,5">
                                    <Button x:Name="btnAddGroupVisitor" Content="Добавить участника" Click="BtnAddGroupVisitor_Click"/>
                                    <Button x:Name="btnRemoveGroupVisitor" Content="Удалить выбранного" Margin="5,0,0,0" Click="BtnRemoveGroupVisitor_Click"/>
                                </StackPanel>
                                <DataGrid x:Name="dgGroupVisitors" AutoGenerateColumns="False" CanUserAddRows="False" Height="200"
          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="№" Binding="{Binding LineNumber}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Организация" Binding="{Binding Organization, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Примечание" Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>
                                        <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="False"/>

                                        <!-- Серия паспорта (4 цифры) -->
                                        <DataGridTemplateColumn Header="Серия паспорта">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding PassportSeries, UpdateSourceTrigger=PropertyChanged}" 
                             MaxLength="4" 
                             PreviewTextInput="TextBoxOnlyDigits_PreviewTextInput"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <!-- Номер паспорта (6 цифр) -->
                                        <DataGridTemplateColumn Header="Номер паспорта">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding PassportNumber, UpdateSourceTrigger=PropertyChanged}" 
                             MaxLength="6" 
                             PreviewTextInput="TextBoxOnlyDigits_PreviewTextInput"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Фото">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Загрузить" Click="BtnLoadGroupVisitorPhoto_Click" Tag="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Скан паспорта">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="PDF" Click="BtnLoadGroupVisitorScan_Click" Tag="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <!-- Документы организатора (скан паспорта организатора) -->
                        <GroupBox Header="Документы организатора" Grid.Row="3" Margin="0,0,0,10">
                            <StackPanel>
                                <Button x:Name="btnLoadOrganizerScan" Content="Загрузить скан паспорта организатора (PDF)" Click="BtnLoadOrganizerScan_Click"/>
                                <TextBlock x:Name="txtOrganizerScanPath" Margin="0,5,0,0" Foreground="Gray"/>
                            </StackPanel>
                        </GroupBox>

                        <Button x:Name="btnSubmitGroup" Content="Отправить групповую заявку" Grid.Row="4" Height="30" Click="BtnSubmitGroup_Click"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>